# TxLINE / Solana config. Copy to .env and fill. .env is gitignored.

# Network: devnet only for now. NEVER set to mainnet without explicit go-ahead.
NETWORK=devnet
TXLINE_BASE=https://txline-dev.txodds.com
SOLANA_RPC=https://api.devnet.solana.com

# Wallet keypair path (gitignored). Generated by scripts/00-wallet.ts.
WALLET_PATH=.wallet/devnet.json

# Filled by the auth/subscribe scripts:
GUEST_JWT=
API_TOKEN=

# Free tier. DEVNET pricing matrix exposes only row_id=1 at price 0 (verified on-chain),
# so use 1 on devnet. (Prose docs mention level 12 = mainnet real-time.)
SERVICE_LEVEL_ID=1
SUBSCRIBE_WEEKS=1
